rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isNotDeactivated() {
      return isAuthenticated() && (!('deactivated' in currentUserDoc()) || currentUserDoc().deactivated != true);
    }

    function isMember() {
      return isAuthenticated() && isNotDeactivated() && currentUserDoc().roles.hasAny(['MEMBER', 'ADMIN', 'SUPERADMIN']);
    }

    function isSuperAdmin() {
      return isMember() && currentUserDoc().roles.hasAny(['SUPERADMIN']);
    }

    function isAdmin() {
      return isMember() && currentUserDoc().roles.hasAny(['SUPERADMIN', 'ADMIN']);
    }

    function isBootswart(boatId) {
      return isMember() && boatId != null && boatId != '' && get(/databases/$(database)/documents/boats/$(boatId)).data.bootswart == request.auth.uid;
    }

    function isAllowedDomain() {
      return request.auth != null && request.auth.token.email != null &&
        (request.auth.token.email.matches('.*@mitglied\\.segelgruppe-kiel\\.de$') || request.auth.token.email.matches('.*@segelgruppe-kiel\\.de$'));
    }

    function hasTimestampRange(data) {
      return data.startTime is timestamp && data.endTime is timestamp && data.endTime > data.startTime;
    }

    function hasValidReservationStatus(status) {
      return ['draft', 'pending', 'approved', 'rejected', 'cancelled'].hasAny([status]);
    }

    function hasValidReservationVisibility(visibility) {
      return ['private', 'public'].hasAny([visibility]);
    }

    function reservationCreateKeysValid() {
      return request.resource.data.keys().hasOnly([
        'boatId', 'userId', 'userName', 'title', 'description', 'startTime', 'endTime', 'status', 'visibility', 'publicDetails', 'eligibilitySnapshot', 'createdAt', 'updatedAt'
      ]);
    }

    function isOwnReservationWrite() {
      return request.resource.data.userId == request.auth.uid && request.resource.data.userName == currentUserDoc().displayName;
    }

    function validReservationCreate() {
      return reservationCreateKeysValid() &&
        request.resource.data.boatId is string &&
        request.resource.data.title is string &&
        hasTimestampRange(request.resource.data) &&
        hasValidReservationStatus(request.resource.data.status) &&
        hasValidReservationVisibility(request.resource.data.visibility) &&
        (!('publicDetails' in request.resource.data) || request.resource.data.publicDetails.freeSeatsText is string) &&
        request.resource.data.eligibilitySnapshot.feesPaid is bool &&
        request.resource.data.eligibilitySnapshot.skipHours is bool &&
        request.resource.data.eligibilitySnapshot.workHoursMet is bool;
    }

    function reservationIdentityUnchanged() {
      return request.resource.data.userId == resource.data.userId &&
        request.resource.data.userName == resource.data.userName &&
        request.resource.data.boatId == resource.data.boatId;
    }

    function ownerCanEditReservation() {
      return resource.data.userId == request.auth.uid &&
        reservationIdentityUnchanged() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'startTime', 'endTime', 'visibility', 'publicDetails', 'status', 'updatedAt']) &&
        (
          // Owner can edit draft reservation fields (status stays draft)
          (resource.data.status == 'draft' && request.resource.data.status == 'draft') ||
          // Owner can finalize draft → pending if eligible
          (resource.data.status == 'draft' &&
            request.resource.data.status == 'pending' &&
            (currentUserDoc().feesPaid == true || currentUserDoc().skipHours == true)) ||
          // Owner can finalize draft → approved only if boat does not require approval
          (resource.data.status == 'draft' &&
            request.resource.data.status == 'approved' &&
            (currentUserDoc().feesPaid == true || currentUserDoc().skipHours == true) &&
            !get(/databases/$(database)/documents/boats/$(resource.data.boatId)).data.requiresApproval) ||
          // Owner can cancel from any active status
          (resource.data.status in ['draft', 'pending', 'approved'] &&
            request.resource.data.status == 'cancelled')
        );
    }

    function validWorkAppointment(data) {
      return data.title is string &&
        data.description is string &&
        data.participants is list &&
        data.supplies is list &&
        hasTimestampRange(data);
    }

    function linkedReservation(reservationId) {
      return get(/databases/$(database)/documents/boatReservations/$(reservationId)).data;
    }

    function canManageLinkedPublicReservation(reservationId) {
      return isMember() &&
        linkedReservation(reservationId) != null &&
        (
          linkedReservation(reservationId).userId == request.auth.uid ||
          isAdmin() ||
          isBootswart(linkedReservation(reservationId).boatId)
        );
    }

    function validPublicReservationProjection(reservationId) {
      return request.resource.data.keys().hasOnly(['boatId', 'boatName', 'title', 'startTime', 'endTime', 'visibility', 'reservationStatus', 'freeSeatsText', 'updatedAt']) &&
        linkedReservation(reservationId) != null &&
        linkedReservation(reservationId).boatId == request.resource.data.boatId &&
        linkedReservation(reservationId).title == request.resource.data.title &&
        linkedReservation(reservationId).startTime == request.resource.data.startTime &&
        linkedReservation(reservationId).endTime == request.resource.data.endTime &&
        linkedReservation(reservationId).visibility == 'public' &&
        !['draft', 'rejected', 'cancelled'].hasAny([linkedReservation(reservationId).status]);
    }

    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isMember();
      allow list: if isMember();

      allow create: if isAdmin() ||
        (request.auth.uid == userId && (
          (isAllowedDomain() && request.resource.data.keys().hasAll(['email', 'displayName', 'roles']) && request.resource.data.roles.hasOnly(['MEMBER']) &&
            (request.resource.data.email.matches('.*@mitglied\\.segelgruppe-kiel\\.de$') || request.resource.data.email.matches('.*@segelgruppe-kiel\\.de$'))) ||
          (request.resource.data.keys().hasAll(['email', 'displayName', 'roles']) && request.resource.data.roles.hasOnly(['APPLICANT']))
        ));

      allow update: if
        (request.auth.uid == userId &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.roles == resource.data.roles &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'lastLoginAt', 'onboardingState', 'updatedAt']) &&
          (!('onboardingState' in request.resource.data) || ['not_started', 'skipped', 'completed'].hasAny([request.resource.data.onboardingState]))) ||
        (isAdmin() && (!request.resource.data.roles.hasAny(['SUPERADMIN']) || (resource.data.roles.hasAny(['SUPERADMIN']) && request.resource.data.roles.hasAny(['SUPERADMIN'])))) ||
        isSuperAdmin();

      allow delete: if isAdmin();
    }

    match /boats/{boatId} {
      allow read: if isMember();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isBootswart(boatId);
    }

    match /boatReservations/{reservationId} {
      allow read: if isMember();
      allow create: if isMember() && isOwnReservationWrite() && validReservationCreate() &&
        (
          isAdmin() ||
          request.resource.data.status == 'draft' ||
          currentUserDoc().feesPaid == true ||
          currentUserDoc().skipHours == true
        );

      allow update: if isAdmin() || isBootswart(resource.data.boatId) || ownerCanEditReservation();

      allow delete: if isAdmin() || (isMember() && resource.data.userId == request.auth.uid && resource.data.status == 'draft');
    }

    match /publicBoatReservations/{reservationId} {
      allow read: if true;
      allow create, update: if isAdmin() || (canManageLinkedPublicReservation(reservationId) && validPublicReservationProjection(reservationId));
      allow delete: if isAdmin() || canManageLinkedPublicReservation(reservationId);
    }

    match /workHours/{docId} {
      allow read: if isMember();
      allow create: if isMember() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isMember() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /workAppointments/{appointmentId} {
      allow read: if isMember();

      allow create: if (isAdmin() || isBootswart(request.resource.data.boatId) ||
        (
          isMember() &&
          request.resource.data.private == true &&
          request.resource.data.participants.size() == 1 &&
          request.resource.data.participants[0].userId == request.auth.uid
        )) && validWorkAppointment(request.resource.data);

      allow update: if isAdmin() || isBootswart(resource.data.boatId) ||
        (isMember() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) && request.resource.data.participants is list) ||
        (isMember() &&
          resource.data.private == true &&
          resource.data.participants.size() == 1 &&
          resource.data.participants[0].userId == request.auth.uid &&
          resource.data.participants[0].status != 'confirmed');

      allow delete: if isAdmin() || isBootswart(resource.data.boatId) || (resource.data.private == true && resource.data.participants.size() == 1 && resource.data.participants[0].userId == request.auth.uid);
    }

    match /systemConfig/default {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
